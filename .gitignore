# =============================================================
# SLCo-Transit-Equity — .gitignore
# =============================================================

# ── R ────────────────────────────────────────────────────────
.Rhistory
.RData
.Ruserdata
.Rapp.history
*.Rproj.user/

# renv cache (the lock file IS committed; the library is not)
renv/library/
renv/local/
renv/cellar/
renv/python/
renv/sandbox/
renv/staging/
.Rprofile        # renv auto-creates this — commit it if present

# ── Quarto ───────────────────────────────────────────────────
/.quarto/
*_files/         # figure/cache dirs generated by quarto render
*_cache/

# ── Spatial Data ─────────────────────────────────────────────
# data/raw/ and data/processed/ are BOTH tracked in git.
#
# Only exclude tigris/tidycensus auto-downloaded CSVs that
# R manages locally and do not belong in the repo:
data/raw/ACS_*.csv
data/raw/ACS_*.zip
#
# If blockgrp_iso.shp turns out >50MB after copying, run:
#   git lfs track "data/processed/blockgrp_iso.shp"
#   git lfs track "data/processed/blockgrp_iso.dbf"
# then commit the resulting .gitattributes file.

# ── API Keys / Secrets ───────────────────────────────────────
.Renviron
.env
secrets.R

# ── OS & Editor junk ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/

# ── Backup / temp files ──────────────────────────────────────
*.bak
*.tmp
Backup/

# ── Output artefacts (rendered by CI, not committed directly) ─
# Uncomment the line below if you use a /docs output-dir for
# GitHub Pages — in that case you WANT docs/ tracked in git.
# docs/

# ── QGIS project ─────────────────────────────────────────────
*.qgz
*.qgs~

# ── Large misc files ─────────────────────────────────────────
*.rar
*.zip
*.xlsx    # Raw data spreadsheets — use CSV in data/ instead
# Exception: keep the renv lockfile
!renv.lock

**/*.quarto_ipynb
.Rproj.user
.positai
